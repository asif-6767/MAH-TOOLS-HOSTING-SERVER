set -euo pipefail

# ------------------------------
# COLOR & STYLE DEFINITIONS
# ------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color
CLEAR='\033[2J\033[H'

# ------------------------------
# GLOBAL VARIABLES
# ------------------------------
PORT=""
SERVER_PID=""
declare -a TUNNEL_PIDS=()
LOG_DIR="$HOME/.alifhostpro/logs"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
CLOUDFLARED_LOG="$LOG_DIR/cloudflared_${TIMESTAMP}.log"
SERVEO_LOG="$LOG_DIR/serveo_${TIMESTAMP}.log"
LOCALHOSTRUN_LOG="$LOG_DIR/localhostrun_${TIMESTAMP}.log"
TUNNELMOLE_LOG="$LOG_DIR/tunnelmole_${TIMESTAMP}.log"

# ------------------------------
# UTILITY FUNCTIONS
# ------------------------------
function cleanup() {
    echo -e "\n${YELLOW}[!] Stopping all tunnels and servers...${NC}"
    # Kill all background tunnel processes
    for pid in "${TUNNEL_PIDS[@]}"; do
        kill -9 "$pid" 2>/dev/null || true
    done
    # Kill local server if started
    if [[ -n "$SERVER_PID" ]]; then
        kill -9 "$SERVER_PID" 2>/dev/null || true
    fi
    # Extra cleanup: kill any remaining cloudflared/ssh/tunnelmole
    pkill -f "cloudflared" 2>/dev/null || true
    pkill -f "serveo.net" 2>/dev/null || true
    pkill -f "localhost.run" 2>/dev/null || true
    pkill -f "tunnelmole" 2>/dev/null || true
    echo -e "${GREEN}[✓] Cleanup completed. Exiting.${NC}"
    exit 0
}

